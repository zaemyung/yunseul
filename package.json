{
	"name": "yunseul",
	"version": "0.1.5",
	"description": "Yunseul (윤슬) — chat with your Obsidian vault using LM Studio or Claude Code.",
	"main": "main.js",
	"type": "module",
	"scripts": {
		"dev": "node esbuild.config.mjs",
		"build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
		"version": "node version-bump.mjs && git add manifest.json versions.json",
		"lint": "eslint .",
		"test": "vitest run",
		"test:watch": "vitest",
		"coverage": "vitest run --coverage"
	},
	"keywords": [
		"obsidian",
		"plugin",
		"ai",
		"chat",
		"local-llm",
		"lm-studio",
		"ollama"
	],
	"license": "MIT",
	"devDependencies": {
		"@eslint/js": "^9.39.4",
		"@types/node": "^22.15.17",
		"@vitest/coverage-v8": "^2.1.9",
		"esbuild": "0.25.5",
		"eslint": "^9.39.4",
		"eslint-plugin-obsidianmd": "^0.3.0",
		"globals": "^17.6.0",
		"jiti": "^2.6.1",
		"jsdom": "^25.0.1",
		"obsidian": "latest",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.59.1",
		"vitest": "^2.1.9"
	}
}
